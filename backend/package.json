{
  "name": "backend",
  "version": "1.0.0",
  "description": "Salary management backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "knex --knexfile knexfile.cjs migrate:latest --env development",
    "migrate:rollback": "knex --knexfile knexfile.cjs migrate:rollback",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "knex": "3.2.10",
    "pg": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.9.1",
    "@types/supertest": "7.2.0",
    "nodemon": "3.1.14",
    "supertest": "7.2.2",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
